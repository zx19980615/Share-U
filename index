<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>質感生活好物分享日誌</title>
  
  <!-- OGP defaults -->
  <meta property="og:title" content="質感生活好物分享日誌 - 最新實測開箱與推薦">
  <meta property="og:description" content="分享日常實用的科技黑科技、生活美學好物、省錢促銷情報與真實心得。">
  <meta property="og:image" content="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=500&auto=format&fit=crop&q=60">
  <meta property="og:type" content="website">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700;900&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg-gradient: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      --card-bg: rgba(30, 41, 59, 0.7);
      --shopee-orange: #ff5722;
      --text-white: #f8fafc;
      --text-gray: #94a3b8;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg-gradient);
      color: var(--text-white);
      font-family: 'Outfit', 'Noto Sans TC', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      position: relative;
      overflow-y: auto;
    }
    body::before {
      content: ''; position: absolute; width: 300px; height: 300px;
      background: radial-gradient(circle, rgba(255, 87, 34, 0.12) 0%, transparent 70%);
      top: -100px; left: -100px; pointer-events: none;
    }
    .container {
      max-width: 480px; width: 100%;
      background: var(--card-bg);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px; padding: 30px;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
      text-align: center; z-index: 10; position: relative;
    }
    .product-img {
      width: 100%; height: 260px; object-fit: cover;
      border-radius: 16px; margin-bottom: 20px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .title { font-size: 1.35rem; font-weight: 700; margin-bottom: 12px; line-height: 1.4; }
    .price-tag { font-size: 1.5rem; font-weight: 800; color: var(--shopee-orange); margin-bottom: 16px; }
    .desc { font-size: 0.925rem; color: var(--text-gray); line-height: 1.6; margin-bottom: 24px; text-align: left; }
    .btn-buy {
      width: 100%; background: linear-gradient(135deg, var(--shopee-orange) 0%, #ff7a00 100%);
      color: white; text-decoration: none; padding: 14px 28px; font-size: 1.05rem;
      font-weight: 700; border: none; border-radius: 14px; cursor: pointer;
      display: inline-flex; align-items: center; justify-content: center; gap: 10px;
      box-shadow: 0 4px 15px rgba(255, 87, 34, 0.4); transition: all 0.2s ease-in-out;
    }
    .btn-buy:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(255, 87, 34, 0.5); }
    .spinner {
      width: 16px; height: 16px; border: 2px solid rgba(255, 87, 34, 0.2);
      border-top-color: var(--shopee-orange); border-radius: 50%;
      animation: spin 1s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    
    /* Blog Mode Styles (when visited directly without product data) */
    .blog-mode { text-align: left; }
    .blog-header { border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 12px; margin-bottom: 20px; }
    .blog-title { font-size: 1.4rem; color: #fff; font-weight: 800; }
    .blog-post {
      padding: 14px; border-radius: 12px; background: rgba(255,255,255,0.02);
      margin-bottom: 12px; border: 1px solid rgba(255,255,255,0.04);
    }
    .blog-post-title { font-size: 0.95rem; font-weight: 700; color: #fff; margin-bottom: 6px; }
    .blog-post-excerpt { font-size: 0.8rem; color: var(--text-gray); line-height: 1.4; }
  </style>
</head>
<body>

  <!-- Dynamic Redirect View -->
  <div class="container" id="human-view" style="display:none;">
    <img class="product-img" id="p-img" src="" alt="Product">
    <h1 class="title" id="p-title">熱門商品好物推薦</h1>
    <div class="price-tag" id="p-price">優選特惠價</div>
    <p class="desc" id="p-desc">正在加載商品詳細開箱心得與實測介紹...</p>
    
    <div class="redirect-status" id="redirect-container" style="margin-bottom: 16px; display: flex; align-items: center; justify-content: center; gap: 8px; font-size:0.85rem; color:var(--text-gray);">
      <div class="spinner"></div>
      <span>安全檢測通過，正在跳轉至官網... (<span id="countdown">2</span>秒)</span>
    </div>

    <button class="btn-buy" id="buy-btn">
      <span>點此直接前往官方選購</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
    </button>
  </div>

  <!-- Safe Crawler / Empty Blog View -->
  <div class="container blog-mode" id="blog-view" style="display:block;">
    <div class="blog-header">
      <div style="font-size: 0.75rem; color: var(--shopee-orange); font-weight: 700; margin-bottom: 4px;">DAILY LOG</div>
      <h2 class="blog-title">質感好物生活日誌</h2>
    </div>
    
    <div class="blog-post">
      <div class="blog-post-title">2026年精選：打造極簡桌面必備的五款質感小物</div>
      <div class="blog-post-excerpt">好的辦公環境能顯著提升工作效率。本篇為大家整理了包含線材收納、恆溫杯墊及智能掛燈等實測心得...</div>
    </div>
    <div class="blog-post">
      <div class="blog-post-title">【實測分享】網購熱銷手持掛燙機開箱與選購重點</div>
      <div class="blog-post-excerpt">每天出門衣服總是皺巴巴？我們自費測試了三款平價掛燙機，從蒸汽出量、加熱速度到手持重量進行完整對比...</div>
    </div>
    <div class="blog-post">
      <div class="blog-post-title">夏日防曬指南：如何挑選真正透氣的防曬外套？</div>
      <div class="blog-post-excerpt">進入高溫梅雨季節，防曬與防紫外線成了每日出門的剛需。本篇為大家解析涼感係數與材質耐磨度...</div>
    </div>
  </div>

  <script>
    (function() {
      // 1. Bot check
      const botPattern = /bot|google|baidu|bing|msn|duckduckbot|teoma|slurp|crawler|spider|facebook|twitter|instagram|threads|discord|telegram|whatsapp|lighthouse|yandex/i;
      const isBot = botPattern.test(navigator.userAgent);

      // 2. Parse Dynamic Payload from URL hash (#data=...)
      const hash = window.location.hash;
      let productData = null;
      let targetUrl = "https://shopee.tw"; // default fallback

      if (hash.startsWith('#data=')) {
        try {
          const base64Data = hash.substring(6);
          // Decode safe UTF-8 base64
          const decodedJson = decodeURIComponent(atob(base64Data).split('').map(function(c) {
            return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
          }).join(''));
          productData = JSON.parse(decodedJson);
          if (productData && productData.url) {
            targetUrl = productData.url;
          }
        } catch(e) {
          console.error("Payload decode error", e);
        }
      }

      // If it is a real human AND we have valid product data, show the redirect container
      if (!isBot && productData) {
        document.getElementById('blog-view').style.display = 'none';
        
        // Populating DOM elements
        document.getElementById('p-title').textContent = productData.title || '質感好物推薦';
        document.getElementById('p-price').textContent = productData.price || '優選特惠價';
        document.getElementById('p-desc').textContent = productData.desc || '全網超熱門話題好物，網友實測極力推薦！手刀點擊按鈕前往官網，享受限時分潤特惠價。';
        if (productData.img) {
          document.getElementById('p-img').src = productData.img;
        } else {
          document.getElementById('p-img').src = 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=500&auto=format&fit=crop&q=60';
        }
        
        document.getElementById('human-view').style.display = 'block';

        // 3. Countdown & Redirection logic
        let count = 2;
        const countdownEl = document.getElementById('countdown');
        const timer = setInterval(() => {
          count--;
          if (countdownEl) countdownEl.textContent = count;
          if (count <= 0) {
            clearInterval(timer);
            window.location.replace(targetUrl);
          }
        }, 1000);

        document.getElementById('buy-btn').addEventListener('click', function() {
          clearInterval(timer);
          window.location.replace(targetUrl);
        });
      }
      // Otherwise keep displaying the blog list (looks like a normal active site to bots/reviewers)
    })();
  </script>
</body>
</html>
